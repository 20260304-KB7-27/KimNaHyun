### 공통 변수
@baseUrl = http://localhost:8080/api/board
@no = 1

# 1. 게시글 전체 목록 조회 (List 반환)
# GET /api/board/list
###############################################
GET {{baseUrl}}/list
Accept: application/json

# 2. 게시글 전체 목록 조회 (ResponseEntity 반환)
# GET /api/board
###############################################
GET {{baseUrl}}
Accept: application/json

###

# 3. 게시글 단건 조회
# GET /api/board/{no}
###############################################
GET {{baseUrl}}/{{no}}
Accept: application/json

###

# 4. 게시글 등록
# POST /api/board
###############################################
POST {{baseUrl}}
Content-Type: application/json

{
  "title": "테스트 제목",
  "content": "테스트 내용입니다.",
  "writer": "홍길동"
}

###

# 5. 게시글 수정
# PUT /api/board/{no}
###############################################
PUT {{baseUrl}}/{{no}}
Content-Type: application/json

{
  "no": 1,
  "title": "수정된 제목",
  "content": "수정된 내용입니다.",
  "writer": "홍길동"
}

###

# 6. 게시글 삭제
# DELETE /api/board/{no}
###############################################
DELETE {{baseUrl}}/{{no}}
Accept: application/json
